
{
  "entities": {
    "School": {
      "title": "School",
      "type": "object",
      "description": "A school tenant in the SaaS system.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "cct": { "type": "string", "description": "Clave de Centro de Trabajo (Official School ID in Mexico)." },
        "address": { "type": "string", "description": "Physical address of the school." },
        "logoUrl": { "type": "string", "description": "URL for the school logo." },
        "activationCode": { "type": "string", "description": "Unique code used by staff and students to join." },
        "directorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "activationCode", "directorId", "createdAt"]
    },
    "UserRole": {
      "title": "UserRole",
      "type": "object",
      "description": "Authorization document linking a user to a school and role.",
      "properties": {
        "role": { "type": "string", "enum": ["Administrador", "Academico", "Alumno"] },
        "schoolId": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["role", "schoolId", "uid"]
    },
    "Student": {
      "title": "Student",
      "type": "object",
      "description": "Student details within a specific school.",
      "properties": {
        "id": { "type": "string" },
        "schoolId": { "type": "string" },
        "studentIdNumber": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "gradeLevel": { "type": "string" },
        "phone": { "type": "string", "description": "Contact phone number." },
        "outstandingBalance": { "type": "number" },
        "guardianName": { "type": "string", "description": "The name of the student's tutor or guardian." }
      },
      "required": ["id", "schoolId", "firstName", "lastName"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "schools": {
      "schema": { "$ref": "#/backend/entities/School" },
      "description": "Top-level schools."
    },
    "staff_roles": {
      "schema": { "$ref": "#/backend/entities/UserRole" },
      "description": "User roles and school associations (indexed by Auth UID)."
    },
    "students": {
      "schema": { "$ref": "#/backend/entities/Student" },
      "description": "Global student list, filtered by schoolId in rules."
    }
  }
}
