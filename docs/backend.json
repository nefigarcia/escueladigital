
{
  "entities": {
    "School": {
      "title": "School",
      "type": "object",
      "description": "A school tenant in the SaaS system.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "cct": { "type": "string" },
        "address": { "type": "string" },
        "logoUrl": { "type": "string" },
        "adminSignatureUrl": { "type": "string" },
        "activationCode": { "type": "string" },
        "directorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "activationCode", "directorId", "createdAt"]
    },
    "UserRole": {
      "title": "UserRole",
      "type": "object",
      "description": "Authorization document linking a user to a school and role.",
      "properties": {
        "role": { "type": "string", "enum": ["Administrador", "Academico", "Alumno"] },
        "schoolId": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "uid": { "type": "string" },
        "studentIdNumber": { "type": "string", "description": "Linking field for students." }
      },
      "required": ["role", "schoolId", "uid"]
    },
    "Student": {
      "title": "Student",
      "type": "object",
      "description": "Student details within a specific school.",
      "properties": {
        "id": { "type": "string" },
        "schoolId": { "type": "string" },
        "studentIdNumber": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "gradeLevel": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "outstandingBalance": { "type": "number" },
        "guardianName": { "type": "string" }
      },
      "required": ["id", "schoolId", "firstName", "lastName"]
    },
    "PsychologyReport": {
      "title": "PsychologyReport",
      "type": "object",
      "description": "Psychological or behavioral observation report for a student.",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "content": { "type": "string" },
        "status": { "type": "string", "enum": ["Borrador", "Finalizado"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "content", "date"]
    },
    "Attendance": {
      "title": "Attendance",
      "type": "object",
      "properties": {
        "classId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "records": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "studentId": { "type": "string" },
              "status": { "type": "string", "enum": ["presente", "ausente", "retardo"] }
            }
          }
        }
      }
    },
    "Grade": {
      "title": "Grade",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "subject": { "type": "string" },
        "score": { "type": "number" },
        "period": { "type": "string" },
        "teacherId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "schools": {
      "schema": { "$ref": "#/backend/entities/School" },
      "description": "Top-level schools."
    },
    "staff_roles": {
      "schema": { "$ref": "#/backend/entities/UserRole" },
      "description": "User roles and school associations."
    },
    "students": {
      "schema": { "$ref": "#/backend/entities/Student" },
      "description": "Global student list."
    },
    "psychology_reports": {
      "schema": { "$ref": "#/backend/entities/PsychologyReport" },
      "description": "Behavioral and psychological reports."
    },
    "attendance": {
      "schema": { "$ref": "#/backend/entities/Attendance" },
      "description": "Daily attendance logs."
    },
    "grades": {
      "schema": { "$ref": "#/backend/entities/Grade" },
      "description": "Academic scores."
    }
  }
}
