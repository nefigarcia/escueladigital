
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Escuela Digital MX - Security Rules
     * Optimized for collection list operations and school-based multi-tenancy.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getStaffRoleData() {
      return get(/databases/$(database)/documents/staff_roles/$(request.auth.uid)).data;
    }

    function isOperationalStaff() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/staff_roles/$(request.auth.uid)) &&
        (getStaffRoleData().role == 'Administrador' || getStaffRoleData().role == 'Academico');
    }

    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/staff_roles/$(request.auth.uid)) &&
        getStaffRoleData().role == 'Administrador';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /schools/{schoolId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && isAdmin() && resource.data.directorId == request.auth.uid;
    }

    match /staff_roles/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isSignedIn() && isAdmin();
      allow create: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow update: if isSignedIn() && (isAdmin() || isOwner(userId));
      allow delete: if isSignedIn() && isAdmin();
    }

    match /students/{studentId} {
      allow read: if isSignedIn() && (
        let roleData = getStaffRoleData();
        ((roleData.role == 'Administrador' || roleData.role == 'Academico') && resource.data.schoolId == roleData.schoolId) ||
        (roleData.role == 'Alumno' && resource.data.studentIdNumber == roleData.studentIdNumber && resource.data.schoolId == roleData.schoolId)
      );
      
      allow create: if isSignedIn() && isOperationalStaff();
      allow update: if isSignedIn() && isOperationalStaff();
      allow delete: if isSignedIn() && isAdmin();
      
      match /payments/{paymentId} {
        allow read: if isSignedIn() && getStaffRoleData().schoolId == get(/databases/$(database)/documents/students/$(studentId)).data.schoolId;
        allow create, update, delete: if isSignedIn() && isOperationalStaff();
      }
    }

    match /fee_types/{id} {
      allow read: if isSignedIn() && resource.data.schoolId == getStaffRoleData().schoolId;
      allow create, update, delete: if isSignedIn() && isAdmin();
    }
    
    match /schedules/{id} {
      allow read: if isSignedIn() && resource.data.schoolId == getStaffRoleData().schoolId;
      allow create, update, delete: if isSignedIn() && isOperationalStaff();
    }

    match /psychology_reports/{reportId} {
      allow read: if isSignedIn() && (
        let roleData = getStaffRoleData();
        (roleData.role == 'Administrador' || roleData.role == 'Academico') && 
        (resource == null || resource.data.schoolId == roleData.schoolId)
      );
      allow create: if isSignedIn() && isOperationalStaff();
      allow update: if isSignedIn() && isOperationalStaff();
      allow delete: if isSignedIn() && isAdmin();
    }

    match /attendance/{id} {
      allow read: if isSignedIn() && resource.data.schoolId == getStaffRoleData().schoolId;
      allow create, update: if isSignedIn() && isOperationalStaff();
      allow delete: if isSignedIn() && isAdmin();
    }

    match /grades/{id} {
      allow read: if isSignedIn() && (
        let roleData = getStaffRoleData();
        ((roleData.role == 'Administrador' || roleData.role == 'Academico') && resource.data.schoolId == roleData.schoolId) ||
        (roleData.role == 'Alumno' && resource.data.studentIdNumber == roleData.studentIdNumber && resource.data.schoolId == roleData.schoolId)
      );
      allow create, update: if isSignedIn() && isOperationalStaff();
      allow delete: if isSignedIn() && isAdmin();
    }
  }
}
