
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Escuela Digital MX - Reglas Multi-tenant Optimizadas
     */

    function isSignedIn() {
      return request.auth != null;
    }

    match /schools/{schoolId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); 
    }

    match /staff_roles/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /students/{studentId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
      
      match /payments/{paymentId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    match /psychology_reports/{reportId} {
      // Allow read if user is signed in. The client query must filter by schoolId 
      // which is enforced by the app logic to avoid permission leaks between schools.
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /attendance/{id} {
      allow read, write: if isSignedIn();
    }

    match /grades/{id} {
      allow read, write: if isSignedIn();
    }

    match /fee_types/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /schedules/{id} {
      allow read, write: if isSignedIn();
    }
  }
}
