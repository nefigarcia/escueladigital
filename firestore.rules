
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/staff_roles/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function sameSchool(docData) {
      return getUserData().schoolId == docData.schoolId;
    }

    // Schools
    match /schools/{schoolId} {
      allow get: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && hasRole('Administrador') && sameSchool(resource.data);
    }

    // Roles (DBAC)
    match /staff_roles/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || (hasRole('Administrador') && sameSchool(get(/databases/$(database)/documents/staff_roles/$(userId)).data)));
      allow create: if isSignedIn();
      allow update: if isSignedIn() && hasRole('Administrador') && sameSchool(resource.data);
    }

    // Students
    match /students/{studentId} {
      allow list: if isSignedIn() && sameSchool(resource.data);
      allow get: if isSignedIn() && sameSchool(resource.data);
      allow create: if isSignedIn() && (hasRole('Administrador') || hasRole('Academico'));
      allow update, delete: if isSignedIn() && hasRole('Administrador') && sameSchool(resource.data);
    }

    // Fees & Payments
    match /fee_types/{id} {
      allow read: if isSignedIn();
      allow write: if hasRole('Administrador');
    }
  }
}
