
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Escuela Digital MX - Security Rules
     * 
     * DBAC Model: Authorization is driven by staff roles.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getStaffRole() {
      return get(/databases/$(database)/documents/staff_roles/$(request.auth.uid)).data.role;
    }

    function hasRole(role) {
      return isSignedIn() && getStaffRole() == role;
    }

    function isAdmin() {
      return hasRole('Administrador');
    }

    function isFinanceStaff() {
      return isAdmin() || hasRole('Contador');
    }

    function isOperationalStaff() {
      return isAdmin() || hasRole('Secretario') || hasRole('Contador') || hasRole('Academico');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function exists(res) {
      return res != null;
    }

    // --- Collection Rules ---

    // Schools
    match /schools/{schoolId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn(); // Directors create the school
      allow update, delete: if isAdmin() && resource.data.directorId == request.auth.uid;
    }

    // Staff Roles
    match /staff_roles/{userId} {
      // Allow user to see their own role, or allow Admin to see everyone
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      // CRITICAL: Allow a new user to create their own initial profile
      allow create: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow update: if isSignedIn() && (isAdmin() || isOwner(userId));
      allow delete: if isAdmin();
    }

    // Students
    match /students/{studentId} {
      allow get, list: if isOperationalStaff() || isAdmin();
      allow create, update: if isOperationalStaff() || isAdmin();
      allow delete: if isAdmin();
      
      // Student subcollections
      match /payments/{paymentId} {
        allow get, list: if isOperationalStaff() || isAdmin();
        allow create: if isFinanceStaff() || isAdmin();
        allow update, delete: if isAdmin();
      }
    }

    // Fee Types
    match /fee_types/{id} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() || isFinanceStaff();
    }
    
    // Schedules
    match /schedules/{id} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() || isOperationalStaff();
    }

    // Psychology Reports
    match /psychology_reports/{reportId} {
      allow read: if isSignedIn() && (isAdmin() || hasRole('Academico'));
      allow create: if isSignedIn() && (isAdmin() || hasRole('Academico'));
      allow update: if isSignedIn() && (isAdmin() || (hasRole('Academico') && resource.data.authorId == request.auth.uid));
      allow delete: if isAdmin();
    }

    // Attendance
    match /attendance/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() || isOperationalStaff();
      allow delete: if isAdmin();
    }

    // Grades
    match /grades/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() || hasRole('Academico');
      allow delete: if isAdmin();
    }
  }
}
