
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Escuela Digital MX - Reglas de Seguridad Centralizadas
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Obtener datos del perfil del usuario (staff o alumno)
    function getProfileData() {
      return get(/databases/$(database)/documents/staff_roles/$(request.auth.uid)).data;
    }

    function isStaff() {
      let role = getProfileData().role;
      return role == 'Administrador' || role == 'Academico';
    }

    function isAdmin() {
      return getProfileData().role == 'Administrador';
    }

    // Regla para validar que el recurso pertenece a la misma escuela que el usuario
    function isSameSchool(schoolId) {
      return schoolId == getProfileData().schoolId;
    }

    match /schools/{schoolId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isAdmin();
    }

    match /staff_roles/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /students/{studentId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isStaff();
      
      match /payments/{paymentId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && isStaff();
      }
    }

    match /psychology_reports/{reportId} {
      // Permitir listado solo si se filtra por la escuela del usuario staff
      allow list: if isSignedIn() && isStaff() && request.query.filters.schoolId == getProfileData().schoolId;
      
      // Permitir lectura individual y escritura si coincide la escuela
      allow get: if isSignedIn() && isStaff() && isSameSchool(resource.data.schoolId);
      allow create, update: if isSignedIn() && isStaff() && isSameSchool(request.resource.data.schoolId);
      allow delete: if isSignedIn() && isAdmin();
    }

    match /attendance/{id} {
      allow read: if isSignedIn() && isSameSchool(resource.data.schoolId);
      allow write: if isSignedIn() && isStaff();
    }

    match /grades/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isStaff();
    }

    match /fee_types/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isAdmin();
    }
    
    match /schedules/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isStaff();
    }
  }
}
