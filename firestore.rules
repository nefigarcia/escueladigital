
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Escuela Digital MX - Reglas de Seguridad Robustas
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Obtener datos del perfil de forma segura
    function getProfile() {
      return get(/databases/$(database)/documents/staff_roles/$(request.auth.uid)).data;
    }

    function isStaff() {
      let profile = getProfile();
      return profile.role == 'Administrador' || profile.role == 'Academico';
    }

    function isAdmin() {
      return getProfile().role == 'Administrador';
    }

    match /schools/{schoolId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isAdmin();
    }

    match /staff_roles/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /students/{studentId} {
      allow read: if isSignedIn() && (getProfile().schoolId == resource.data.schoolId || request.auth.uid == studentId);
      allow write: if isSignedIn() && isStaff();
      
      match /payments/{paymentId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && isStaff();
      }
    }

    match /psychology_reports/{reportId} {
      // Regla de lectura unificada para listado y lectura individual
      // En operaciones de listado, Firestore exige que la consulta tenga el filtro schoolId
      allow read: if isSignedIn() && isStaff() && resource.data.schoolId == getProfile().schoolId;
      allow create, update: if isSignedIn() && isStaff() && request.resource.data.schoolId == getProfile().schoolId;
      allow delete: if isSignedIn() && isAdmin();
    }

    match /attendance/{id} {
      allow read: if isSignedIn() && resource.data.schoolId == getProfile().schoolId;
      allow write: if isSignedIn() && isStaff();
    }

    match /grades/{id} {
      allow read: if isSignedIn() && (resource == null || resource.data.schoolId == getProfile().schoolId);
      allow write: if isSignedIn() && isStaff();
    }

    match /fee_types/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isAdmin();
    }
    
    match /schedules/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isStaff();
    }
  }
}
