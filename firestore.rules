rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Escuela Digital MX - Reglas de Seguridad Simplificadas
     * Optimizadas para evitar errores de permisos en operaciones de listado.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function getStaff() {
      return get(/databases/$(database)/documents/staff_roles/$(request.auth.uid)).data;
    }

    match /schools/{schoolId} {
      allow read: if true;
      allow write: if isSignedIn() && getStaff().role == 'Administrador';
    }

    match /staff_roles/{userId} {
      allow read, write: if isSignedIn();
    }

    match /students/{studentId} {
      allow read: if isSignedIn() && resource.data.schoolId == getStaff().schoolId;
      allow write: if isSignedIn() && (getStaff().role == 'Administrador' || getStaff().role == 'Academico');
      
      match /payments/{paymentId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (getStaff().role == 'Administrador' || getStaff().role == 'Academico');
      }
    }

    match /psychology_reports/{reportId} {
      // Regla simplificada para permitir listados basados en schoolId
      allow read: if isSignedIn() && 
                    (resource == null || resource.data.schoolId == getStaff().schoolId) &&
                    (getStaff().role == 'Administrador' || getStaff().role == 'Academico');
      
      allow create: if isSignedIn() && 
                      request.resource.data.schoolId == getStaff().schoolId && 
                      (getStaff().role == 'Administrador' || getStaff().role == 'Academico');
      
      allow update: if isSignedIn() && 
                      resource.data.schoolId == getStaff().schoolId && 
                      (getStaff().role == 'Administrador' || getStaff().role == 'Academico');
      
      allow delete: if isSignedIn() && 
                      resource.data.schoolId == getStaff().schoolId && 
                      getStaff().role == 'Administrador';
    }

    match /attendance/{id} {
      allow read: if isSignedIn() && (resource == null || resource.data.schoolId == getStaff().schoolId);
      allow write: if isSignedIn() && (getStaff().role == 'Administrador' || getStaff().role == 'Academico');
    }

    match /grades/{id} {
      allow read: if isSignedIn() && (resource == null || resource.data.schoolId == getStaff().schoolId);
      allow write: if isSignedIn() && (getStaff().role == 'Administrador' || getStaff().role == 'Academico');
    }

    match /fee_types/{id} {
      allow read: if isSignedIn() && (resource == null || resource.data.schoolId == getStaff().schoolId);
      allow write: if isSignedIn() && getStaff().role == 'Administrador';
    }
    
    match /schedules/{id} {
      allow read: if isSignedIn() && (resource == null || resource.data.schoolId == getStaff().schoolId);
      allow write: if isSignedIn() && (getStaff().role == 'Administrador' || getStaff().role == 'Academico');
    }

    match /fee_types/{id} {
      allow read: if isSignedIn() && (resource == null || resource.data.schoolId == getStaff().schoolId);
      allow create, update, delete: if isSignedIn() && getStaff().role == 'Administrador';
    }
  }
}