
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Escuela Digital MX - Security Rules
     * 
     * DBAC Model: Authorization is driven by staff roles and school isolation.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getStaffRoleData() {
      return get(/databases/$(database)/documents/staff_roles/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && exists(/databases/$(database)/documents/staff_roles/$(request.auth.uid)) && getStaffRoleData().role == role;
    }

    function isAdmin() {
      return hasRole('Administrador');
    }

    function isOperationalStaff() {
      return isAdmin() || hasRole('Academico');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSameSchool(resourceData) {
      return isSignedIn() && exists(/databases/$(database)/documents/staff_roles/$(request.auth.uid)) && resourceData.schoolId == getStaffRoleData().schoolId;
    }

    // --- Collection Rules ---

    match /schools/{schoolId} {
      // Allow public read to verify activation codes during registration
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() && resource.data.directorId == request.auth.uid;
    }

    match /staff_roles/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow update: if isSignedIn() && (isAdmin() || isOwner(userId));
      allow delete: if isAdmin();
    }

    match /students/{studentId} {
      // Admins/Staff can read all in their school. 
      // Alumnos can only read their own record based on studentIdNumber.
      allow read: if isSignedIn() && (
        ((isOperationalStaff() || isAdmin()) && isSameSchool(resource.data)) ||
        (hasRole('Alumno') && isSameSchool(resource.data) && resource.data.studentIdNumber == getStaffRoleData().studentIdNumber)
      );
      
      allow create: if isSignedIn() && (isOperationalStaff() || isAdmin()) && request.resource.data.schoolId == getStaffRoleData().schoolId;
      allow update: if isSignedIn() && (isOperationalStaff() || isAdmin()) && isSameSchool(resource.data);
      allow delete: if isAdmin() && isSameSchool(resource.data);
      
      match /payments/{paymentId} {
        allow read: if isSignedIn() && (
          ((isOperationalStaff() || isAdmin()) && isSameSchool(get(/databases/$(database)/documents/students/$(studentId)).data)) ||
          (hasRole('Alumno') && isSameSchool(get(/databases/$(database)/documents/students/$(studentId)).data) && get(/databases/$(database)/documents/students/$(studentId)).data.studentIdNumber == getStaffRoleData().studentIdNumber)
        );
        allow create, update, delete: if isSignedIn() && (isOperationalStaff() || isAdmin()) && isSameSchool(get(/databases/$(database)/documents/students/$(studentId)).data);
      }
    }

    match /fee_types/{id} {
      allow read: if isSignedIn() && isSameSchool(resource.data);
      allow create: if isSignedIn() && isAdmin() && request.resource.data.schoolId == getStaffRoleData().schoolId;
      allow update, delete: if isSignedIn() && isAdmin() && isSameSchool(resource.data);
    }
    
    match /schedules/{id} {
      allow read: if isSignedIn() && isSameSchool(resource.data);
      allow create: if isSignedIn() && (isAdmin() || isOperationalStaff()) && request.resource.data.schoolId == getStaffRoleData().schoolId;
      allow update, delete: if isSignedIn() && (isAdmin() || isOperationalStaff()) && isSameSchool(resource.data);
    }

    match /psychology_reports/{reportId} {
      allow read: if isSignedIn() && (isAdmin() || hasRole('Academico')) && isSameSchool(resource.data);
      allow create: if isSignedIn() && (isAdmin() || hasRole('Academico')) && request.resource.data.schoolId == getStaffRoleData().schoolId;
      allow update: if isSignedIn() && (isAdmin() || (hasRole('Academico') && resource.data.authorId == request.auth.uid)) && isSameSchool(resource.data);
      allow delete: if isAdmin() && isSameSchool(resource.data);
    }

    match /attendance/{id} {
      allow read: if isSignedIn() && (
        ((isAdmin() || isOperationalStaff()) && isSameSchool(resource.data)) ||
        (hasRole('Alumno') && isSameSchool(resource.data))
      );
      allow create, update: if isSignedIn() && (isAdmin() || isOperationalStaff()) && request.resource.data.schoolId == getStaffRoleData().schoolId;
      allow delete: if isAdmin() && isSameSchool(resource.data);
    }

    match /grades/{id} {
      allow read: if isSignedIn() && (
        ((isAdmin() || hasRole('Academico')) && isSameSchool(resource.data)) ||
        (hasRole('Alumno') && isSameSchool(resource.data) && resource.data.studentIdNumber == getStaffRoleData().studentIdNumber)
      );
      allow create, update: if isSignedIn() && (isAdmin() || hasRole('Academico')) && request.resource.data.schoolId == getStaffRoleData().schoolId;
      allow delete: if isAdmin() && isSameSchool(resource.data);
    }
  }
}
